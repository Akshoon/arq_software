# Configuración de Claves de API (Exclusivo Google Gemini)
# Si la key principal falla por cuota/rate-limit, se rotará automáticamente a la siguiente.
# Agrega tantas cuentas de Google AI Studio como quieras (GEMINI_API_KEY_2, _3, _4, etc.)
GEMINI_API_KEY=tu_clave_gemini_aqui
GEMINI_API_KEY_2=tu_segunda_clave_aqui
GEMINI_API_KEY_3=tu_tercera_clave_aqui
GEMINI_MODEL=gemini-1.5-flash

# Configuración del Servidor Web
PORT=5000
